# clangd configuration for IDE diagnostics (does NOT affect the devkitARM build).
#
# clangd otherwise has no idea about the arm-none-eabi cross toolchain and floods
# every file with false "unknown type u16/FIL" / "file not found" errors. These
# flags give it the target and silence gcc-only attribute warnings.
#
# Header search paths (devkitPro + this repo) are MACHINE-SPECIFIC, so they are
# NOT hard-coded here. They live in compile_commands.json, which is generated by
# tools/gen-compile-commands.sh and is gitignored. Run that once after cloning
# (and again whenever you add or remove source files):
#
#     ./tools/gen-compile-commands.sh
CompileFlags:
  Add:
    - --target=arm-none-eabi
    - -mthumb
    - -mcpu=arm7tdmi
    - -Wno-unknown-attributes # clang doesn't know gcc's long_call/section attrs
Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
